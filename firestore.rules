rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isUser(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function onlyKeysChanged(allowed) {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(allowed);
    }

    function conversationParticipant(conv) {
      return signedIn() &&
        (conv.data.userId == request.auth.uid || conv.data.caregiverId == request.auth.uid);
    }

    match /users/{userId} {
      allow read: if isUser(userId);
      allow create: if isUser(userId) && request.resource.data.id == userId;
      allow update: if isUser(userId);
      allow delete: if isUser(userId);

      match /notifications/{notificationId} {
        allow read: if isUser(userId);
        allow create: if signedIn() &&
          request.resource.data.userId == userId &&
          request.resource.data.senderUserId == request.auth.uid;
        allow update, delete: if isUser(userId);
      }
    }

    match /caregivers/{caregiverId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() &&
        (resource == null || resource.data.userId == request.auth.uid) &&
        request.resource.data.userId == request.auth.uid;
    }

    match /bookings/{bookingId} {
      allow read: if signedIn() &&
        (resource.data.userId == request.auth.uid || resource.data.caregiverId == request.auth.uid);

      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;

      allow update: if signedIn() && (
        (resource.data.userId == request.auth.uid && onlyKeysChanged(["status", "cancellationRequestedByUid", "cancellationRequestedByRole", "cancellationRequestedAt"])) ||
        (resource.data.caregiverId == request.auth.uid && onlyKeysChanged(["status", "cancellationRequestedByUid", "cancellationRequestedByRole", "cancellationRequestedAt"]))
      );

      allow delete: if false;
    }

    match /bookingAudits/{auditId} {
      allow read, write: if false;
    }

    match /connections/{connectionId} {
      allow read: if signedIn() &&
        (resource.data.userId == request.auth.uid || resource.data.caregiverId == request.auth.uid);

      allow create: if signedIn() &&
        (request.resource.data.userId == request.auth.uid ||
         request.resource.data.caregiverId == request.auth.uid);

      allow update: if signedIn() &&
        (resource.data.userId == request.auth.uid || resource.data.caregiverId == request.auth.uid) &&
        onlyKeysChanged(["status"]);

      allow delete: if false;
    }

    match /conversations/{conversationId} {
      allow read: if signedIn() &&
        (resource.data.userId == request.auth.uid || resource.data.caregiverId == request.auth.uid);

      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.caregiverId is string;

      allow update: if signedIn() &&
        (resource.data.userId == request.auth.uid || resource.data.caregiverId == request.auth.uid);

      match /messages/{messageId} {
        allow read: if signedIn() && conversationParticipant(
          get(/databases/$(database)/documents/conversations/$(conversationId))
        );

        allow create: if signedIn() && conversationParticipant(
          get(/databases/$(database)/documents/conversations/$(conversationId))
        ) &&
        request.resource.data.senderId == request.auth.uid;

        allow update: if signedIn() && conversationParticipant(
          get(/databases/$(database)/documents/conversations/$(conversationId))
        );

        allow delete: if false;
      }
    }

    match /familyMembers/{memberId} {
      allow read: if signedIn() && resource.data.ownerUserId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.ownerUserId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.ownerUserId == request.auth.uid;
    }

    match /medicalRecords/{recordId} {
      allow read: if signedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.caregiverId == request.auth.uid
      );

      allow create: if signedIn() &&
        (request.resource.data.patientId == request.auth.uid ||
         request.resource.data.caregiverId == request.auth.uid);

      allow update, delete: if signedIn() &&
        (resource.data.patientId == request.auth.uid ||
         resource.data.caregiverId == request.auth.uid);
    }

    match /reviews/{reviewId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
